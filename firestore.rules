rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Lookup user document theo UID (doc mới) HOẶC theo email-key (doc cũ)
    // vì một số user được tạo trước khi app chuẩn hóa docId = uid,
    // nên docId của họ có thể là email.replace('.','_') thay vì uid.
    function getUserData() {
      let byUid   = exists(/databases/$(database)/documents/users/$(request.auth.uid))
                    ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
                    : null;
      // Nếu đã tìm thấy theo UID thì dùng luôn, không cần fallback
      return byUid;
    }

    function getRole() {
      let d = getUserData();
      return d != null ? d.role : null;
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    function isOperator() {
      return isSignedIn() && (getRole() == 'admin' || getRole() == 'operator');
    }

    // Roles được phép sửa lô hàng: admin, operator, doc, cus
    function canEditLot() {
      return isSignedIn() && (
        getRole() == 'admin'    ||
        getRole() == 'operator' ||
        getRole() == 'doc'      ||
        getRole() == 'cus'
      );
    }

    // Roles có quyền manageFinance: admin + accountant
    function canManageFinance() {
      return isSignedIn() && (
        getRole() == 'admin' ||
        getRole() == 'accountant'
      );
    }

    // Roles được ghi cashTransactions (bao gồm ghi tự động khi tick TT lô hàng)
    function canWriteCashTx() {
      return isSignedIn() && (
        getRole() == 'admin'      ||
        getRole() == 'accountant' ||
        getRole() == 'operator'   ||
        getRole() == 'doc'        ||
        getRole() == 'cus'
      );
    }

    // ── Lô hàng ──────────────────────────────────────────
    match /lots_xuat/{docId} {
      allow read:   if isSignedIn();
      allow create: if canEditLot();
      allow update: if canEditLot();
      allow delete: if isAdmin();
    }

    match /lots_nhap/{docId} {
      allow read:   if isSignedIn();
      allow create: if canEditLot();
      allow update: if canEditLot();
      allow delete: if isAdmin();
    }

    // ── Đối tác ───────────────────────────────────────────
    match /partners/{docId} {
      allow read:   if isSignedIn();
      allow create: if isOperator();
      allow update: if isOperator();
      allow delete: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────
    match /users/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }

    // profiles: mỗi user chỉ ghi doc của chính mình (lưu lastPasswordChange)
    match /profiles/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn() && request.auth.uid == docId;
    }

    // ── Cấu hình hệ thống ────────────────────────────────
    match /_config/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Ghi chú riêng (mỗi user chỉ đọc/ghi ghi chú của chính mình) ──
    match /personalNotes/{docId} {
      allow read, write: if isSignedIn() && (
        !exists(/databases/$(database)/documents/personalNotes/$(docId)) ||
        resource.data.owner == request.auth.token.email
      );
    }

    // ── Lịch cá nhân (Ghi chú riêng → "Lịch của tôi") — mỗi user chỉ đọc/ghi của chính mình ──
    match /personalCalendarTasks/{docId} {
      allow read, write: if isSignedIn() && (
        !exists(/databases/$(database)/documents/personalCalendarTasks/$(docId)) ||
        resource.data.owner == request.auth.token.email
      );
    }

    // ── Module Lịch (COCO NOTES → tab Lịch) — công việc dùng chung cả team ──
    match /calendarTasks/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Bảng tra cứu username → email (cần đọc CÔNG KHAI để hỗ trợ đăng nhập bằng
    // tên đăng nhập trước khi xác thực xong; chỉ admin được ghi/sửa) ──
    match /usernameMap/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Dữ liệu thị trường (Market Data) — import từ Excel hải quan để phân tích đối thủ/khách hàng ──
    match /marketShippers/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /marketTransactions/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Danh mục ─────────────────────────────────────────
    match /ocean_rates/{docId} {
      allow read:   if isSignedIn();
      allow create: if isOperator();
      allow update: if isOperator();
      allow delete: if isAdmin();
    }

    match /quotes/{docId} {
      allow read:   if isSignedIn();
      allow create: if isOperator();
      allow update: if isOperator();
      allow delete: if isAdmin();
    }

    match /vessels/{docId} {
      allow read:   if isSignedIn();
      allow create: if isOperator();
      allow update: if isOperator();
      allow delete: if isAdmin();
    }

    // ── Quản lý thu chi ──────────────────────────────────
    match /cashTransactions/{docId} {
      allow read:   if isSignedIn();
      allow create: if canWriteCashTx();
      allow update: if canManageFinance();
      allow delete: if isAdmin();
    }

    match /debtEntries/{docId} {
      allow read:   if isSignedIn();
      allow create: if canManageFinance();
      allow update: if canManageFinance();
      allow delete: if isAdmin();
    }

    // payroll: Bảng lương nhân viên (theo tháng)
    match /payroll/{docId} {
      allow read:   if isSignedIn();
      allow create: if canManageFinance();
      allow update: if canManageFinance();
      allow delete: if isAdmin();
    }

  }
}
