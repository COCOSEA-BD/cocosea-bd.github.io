rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserDoc().role;
    }

    function isAdmin()    { return isSignedIn() && getRole() == 'admin'; }
    function isOperator() { return isSignedIn() && (getRole() == 'admin' || getRole() == 'operator'); }

    match /lots_xuat/{docId} {
      allow read:   if isSignedIn();
      allow create: if isOperator();
      allow update: if isOperator();
      allow delete: if isAdmin();
    }

    match /lots_nhap/{docId} {
      allow read:   if isSignedIn();
      allow create: if isOperator();
      allow update: if isOperator();
      allow delete: if isAdmin();
    }

    match /partners/{docId} {
      allow read:   if isSignedIn();
      allow create: if isOperator();
      allow update: if isOperator();
      allow delete: if isAdmin();
    }

    match /users/{docId} {
      // Any signed-in user can read (needed for profile lookup by UID or email)
      allow read:   if isSignedIn();
      // Admin can write all user docs
      allow write:  if isAdmin();
    }

    match /_config/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

  }
}
