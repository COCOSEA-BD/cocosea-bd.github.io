rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Debit Note upload theo từng dịch vụ
    match /dn-uploads/{tt}/{lotId}/{fileName} {
      allow read, write: if request.auth != null;
    }
    // Chứng từ upload trong tab Document của lô hàng
    match /lot-docs/{tt}/{lotId}/{fileName} {
      allow read, write: if request.auth != null;
    }
    // Tệp đính kèm công việc trong module Lịch (COCO NOTES → tab Lịch)
    match /calendar-attachments/{fileName} {
      allow read, write: if request.auth != null;
    }
    // Mặc định: từ chối mọi thứ khác
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
